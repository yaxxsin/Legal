# ============================================
# LocalCompliance — Environment Variables
# Copy to .env.local and fill in values
# ============================================

# === Supabase ===
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# === Database ===
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# === NestJS API ===
API_PORT=3001
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development

# === Frontend API URL ===
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# === AI Services (Phase 5+) ===
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_AI_API_KEY=
# PINECONE_API_KEY=
# PINECONE_INDEX=localcompliance

# === Email (Phase 1+) ===
# RESEND_API_KEY=

# === Payment (Phase 15+) ===
# Get your sandbox keys from: https://dashboard.sandbox.midtrans.com/settings/config_info
MIDTRANS_SERVER_KEY=SB-Mid-server-YOUR_SANDBOX_KEY
MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_SANDBOX_KEY
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-YOUR_SANDBOX_KEY
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# === Monitoring ===
# SENTRY_DSN=
# DATADOG_API_KEY=
