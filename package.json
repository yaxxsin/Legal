{
  "name": "localcompliance",
  "version": "0.1.0",
  "private": true,
  "description": "AI-Powered Business Legal Compliance Platform for Indonesian SMEs",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "db:generate": "pnpm --filter @localcompliance/api exec prisma generate",
    "db:push": "pnpm --filter @localcompliance/api exec prisma db push",
    "db:migrate": "pnpm --filter @localcompliance/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @localcompliance/api exec prisma db seed",
    "db:studio": "pnpm --filter @localcompliance/api exec prisma studio",
    "clean": "turbo run clean && rimraf node_modules"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.4",
  "devDependencies": {
    "turbo": "^2.3.0",
    "prettier": "^3.4.0",
    "rimraf": "^6.0.0"
  }
}
