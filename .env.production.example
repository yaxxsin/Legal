# ============================================
# LocalCompliance — Production Environment
# Copy to .env on your Proxmox server
# ============================================
# Port Map (all non-standard to avoid conflicts):
#   Web (FE)       → 4580
#   API            → 4581
#   PostgreSQL     → 4582
#   Redis          → 4583
#   MinIO API      → 4584
#   MinIO Console  → 4585
# ============================================

# === Database ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_HERE
POSTGRES_DB=localcompliance

# === Redis ===
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD

# === JWT ===
JWT_SECRET=CHANGE_ME_MIN_32_CHARS_RANDOM_STRING_HERE_1234567890
JWT_EXPIRATION=1h
JWT_REFRESH_EXPIRATION=30d

# === CORS (your production domain) ===
CORS_ORIGIN=https://yourdomain.com

# === MinIO ===
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME_STRONG_MINIO_PASSWORD

# === Cloudflare Tunnel ===
# cloudflared sudah terpasang di server
# Config hostname di Zero Trust Dashboard → http://localhost:4580

# === AI Services ===
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen2.5

# === Pasal API ===
PASAL_API_URL=https://pasal.id/api/v1
PASAL_API_TOKEN=your_pasal_token_here

# === Sentry (optional) ===
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@sentry.io/xxx
